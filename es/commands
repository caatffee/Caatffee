<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Comandos — Caatffee Bot</title>
  <meta name="description" content="Lista completa de comandos de Caatffee, el bot de gestión y moderación para Discord."/>
  <link rel="canonical" href="https://caatffee.com/es/commands"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #0b0c10;
      --surface: #111318;
      --surface2: #181b22;
      --border: rgba(255,255,255,0.07);
      --accent: #c8a96e;
      --accent2: #e8c98e;
      --accent-glow: rgba(200,169,110,0.18);
      --text: #f0ece3;
      --muted: #7a7870;
      --radius: 14px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 16px;
      line-height: 1.6;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.025;
      pointer-events: none;
      z-index: 9999;
    }

    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 48px;
      background: rgba(11,12,16,0.85);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: 1.4rem;
      color: var(--accent);
      letter-spacing: -0.01em;
      text-decoration: none;
      display: flex; align-items: center; gap: 10px;
    }

    .nav-logo svg { width: 28px; height: 28px; }

    .nav-links { display: flex; align-items: center; gap: 32px; list-style: none; }

    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: color 0.2s;
      letter-spacing: 0.02em;
    }

    .nav-links a:hover { color: var(--text); }
    .nav-links a.active { color: var(--accent); }

    .btn-invite {
      background: var(--accent);
      color: #0b0c10;
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 0.85rem;
      padding: 10px 22px;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }

    .btn-invite:hover { background: var(--accent2); transform: translateY(-1px); }

    /* ── PAGE HEADER ── */
    .page-header {
      padding: 140px 24px 60px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .page-header::before {
      content: '';
      position: absolute;
      top: -100px; left: 50%; transform: translateX(-50%);
      width: 600px; height: 500px;
      background: radial-gradient(circle, rgba(200,169,110,0.1) 0%, transparent 70%);
      pointer-events: none;
    }

    .page-header-inner { position: relative; z-index: 1; }

    .breadcrumb {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 0.8rem; color: var(--muted);
      margin-bottom: 20px;
    }

    .breadcrumb a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--accent); }
    .breadcrumb span { color: var(--accent); }

    .page-header h1 {
      font-family: 'Syne', sans-serif;
      font-weight: 800;
      font-size: clamp(2.2rem, 5vw, 3.6rem);
      letter-spacing: -0.03em;
      line-height: 1.05;
      animation: fadeUp 0.5s ease both;
    }

    .page-header p {
      color: var(--muted);
      font-size: 1.05rem;
      max-width: 480px;
      margin: 16px auto 0;
      animation: fadeUp 0.5s 0.1s ease both;
    }

    .cmd-count-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--accent-glow);
      border: 1px solid rgba(200,169,110,0.25);
      color: var(--accent);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 20px;
      animation: fadeUp 0.5s 0s ease both;
    }

    /* ── SEARCH BAR ── */
    .search-wrap {
      max-width: 480px;
      margin: 32px auto 0;
      position: relative;
      animation: fadeUp 0.5s 0.2s ease both;
    }

    .search-wrap svg {
      position: absolute;
      left: 16px; top: 50%; transform: translateY(-50%);
      color: var(--muted);
      pointer-events: none;
    }

    #search-input {
      width: 100%;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 16px 14px 46px;
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    #search-input::placeholder { color: var(--muted); }
    #search-input:focus { border-color: rgba(200,169,110,0.35); box-shadow: 0 0 0 3px rgba(200,169,110,0.08); }

    /* ── FILTER TABS ── */
    .filter-tabs {
      display: flex; align-items: center; justify-content: center; gap: 8px;
      flex-wrap: wrap;
      padding: 32px 24px 0;
      max-width: 900px;
      margin: 0 auto;
    }

    .tab-btn {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--muted);
      font-family: 'DM Sans', sans-serif;
      font-size: 0.83rem;
      font-weight: 500;
      padding: 8px 16px;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.2s;
      display: flex; align-items: center; gap: 6px;
    }

    .tab-btn:hover { color: var(--text); border-color: rgba(200,169,110,0.2); }

    .tab-btn.active {
      background: var(--accent-glow);
      border-color: rgba(200,169,110,0.3);
      color: var(--accent);
    }

    /* ── COMMANDS GRID ── */
    .commands-page { padding: 40px 24px 100px; }

    .commands-container { max-width: 1100px; margin: 0 auto; }

    .category-section {
      margin-bottom: 52px;
    }

    .category-header {
      display: flex; align-items: center; gap: 14px;
      margin-bottom: 20px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--border);
    }

    .category-icon {
      width: 40px; height: 40px;
      background: var(--accent-glow);
      border: 1px solid rgba(200,169,110,0.2);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
      flex-shrink: 0;
    }

    .category-name {
      font-family: 'Syne', sans-serif;
      font-weight: 700;
      font-size: 1rem;
    }

    .category-count {
      margin-left: auto;
      background: var(--surface2);
      border: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 100px;
    }

    .cmd-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 10px;
    }

    .cmd-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 18px 20px;
      display: flex; align-items: flex-start; gap: 14px;
      transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
      cursor: default;
    }

    .cmd-card:hover {
      border-color: rgba(200,169,110,0.22);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }

    .cmd-card.hidden { display: none; }

    .cmd-num {
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--muted);
      min-width: 22px;
      padding-top: 2px;
      font-family: 'Syne', sans-serif;
    }

    .cmd-info { flex: 1; min-width: 0; }

    .cmd-tag {
      font-family: 'DM Sans', monospace;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--accent);
      display: flex; align-items: center; gap: 6px;
      margin-bottom: 4px;
    }

    .cmd-tag .emoji { font-size: 0.9rem; }

    .cmd-description { color: var(--muted); font-size: 0.82rem; line-height: 1.5; }

    /* no results */
    .no-results {
      text-align: center;
      padding: 60px 20px;
      color: var(--muted);
      display: none;
    }

    .no-results-icon { font-size: 2.5rem; margin-bottom: 12px; }
    .no-results h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.1rem; color: var(--text); margin-bottom: 8px; }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    footer {
      border-top: 1px solid var(--border);
      padding: 36px 48px;
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 20px;
    }

    .footer-logo { font-family: 'Syne', sans-serif; font-weight: 800; color: var(--accent); font-size: 1.1rem; text-decoration: none; }
    .footer-links { display: flex; gap: 28px; list-style: none; }
    .footer-links a { color: var(--muted); text-decoration: none; font-size: 0.85rem; transition: color 0.2s; }
    .footer-links a:hover { color: var(--text); }
    .footer-copy { color: var(--muted); font-size: 0.8rem; }

    @media (max-width: 768px) {
      nav { padding: 16px 20px; }
      .nav-links { display: none; }
      footer { padding: 28px 20px; flex-direction: column; text-align: center; }
      .cmd-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="/es" class="nav-logo">
      <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="14" cy="14" r="13" stroke="#c8a96e" stroke-width="1.5"/>
        <path d="M8 14c0-3.314 2.686-6 6-6s6 2.686 6 6-2.686 6-6 6" stroke="#c8a96e" stroke-width="1.5" stroke-linecap="round"/>
        <circle cx="14" cy="14" r="2.5" fill="#c8a96e"/>
      </svg>
      Caatffee
    </a>
    <ul class="nav-links">
      <li><a href="/es">Inicio</a></li>
      <li><a href="/es/commands" class="active">Comandos</a></li>
      <li><a href="/es#features">Características</a></li>
    </ul>
    <a href="https://discord.com/oauth2/authorize" class="btn-invite" target="_blank">Invitar bot →</a>
  </nav>

  <header class="page-header">
    <div class="page-header-inner">
      <div class="breadcrumb">
        <a href="/es">Inicio</a> › <span>Comandos</span>
      </div>
      <div class="cmd-count-badge">📋 40 Comandos disponibles</div>
      <h1>Lista de Comandos</h1>
      <p>Todos los comandos de Caatffee organizados por categoría. Usa el buscador para encontrar lo que necesitas.</p>
      <div class="search-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input id="search-input" type="text" placeholder="Buscar comando..." autocomplete="off"/>
      </div>
    </div>
  </header>

  <!-- FILTER TABS -->
  <div class="filter-tabs">
    <button class="tab-btn active" data-filter="all">🔍 Todos</button>
    <button class="tab-btn" data-filter="info">📂 Información</button>
    <button class="tab-btn" data-filter="crear">🛠️ Creación</button>
    <button class="tab-btn" data-filter="editar">✏️ Edición</button>
    <button class="tab-btn" data-filter="borrar">🗑️ Eliminación</button>
    <button class="tab-btn" data-filter="mod">🛡️ Moderación</button>
    <button class="tab-btn" data-filter="config">⚙️ Configuración</button>
  </div>

  <!-- COMMANDS -->
  <div class="commands-page">
    <div class="commands-container">

      <!-- INFORMACIÓN -->
      <div class="category-section" data-cat="info">
        <div class="category-header">
          <div class="category-icon">📂</div>
          <span class="category-name">Información y General</span>
          <span class="category-count">4 comandos</span>
        </div>
        <div class="cmd-grid">
          <div class="cmd-card" data-cat="info" data-name="/help">
            <span class="cmd-num">01</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🆘</span>/help</div>
              <div class="cmd-description">Aprende a usar el bot y consulta el manual de comandos.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="info" data-name="/update">
            <span class="cmd-num">02</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">⭐</span>/update</div>
              <div class="cmd-description">Ver la última actualización del bot y todo lo que contiene.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="info" data-name="/dashboard-server">
            <span class="cmd-num">03</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🏡</span>/dashboard-server</div>
              <div class="cmd-description">Ver el panel completo del servidor con estadísticas en tiempo real.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="info" data-name="/user-info">
            <span class="cmd-num">04</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">👤</span>/user-info</div>
              <div class="cmd-description">Mira detalles de un usuario: roles, ID, fecha de ingreso, y más.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- CREACIÓN -->
      <div class="category-section" data-cat="crear">
        <div class="category-header">
          <div class="category-icon">🛠️</div>
          <span class="category-name">Creación</span>
          <span class="category-count">6 comandos</span>
        </div>
        <div class="cmd-grid">
          <div class="cmd-card" data-cat="crear" data-name="/create-channel">
            <span class="cmd-num">05</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🛠️</span>/create-channel</div>
              <div class="cmd-description">Crear un nuevo canal de texto o voz en el servidor.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="crear" data-name="/create-category">
            <span class="cmd-num">06</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🛠️</span>/create-category</div>
              <div class="cmd-description">Crear una nueva categoría para organizar los canales.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="crear" data-name="/create-event">
            <span class="cmd-num">07</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🛠️</span>/create-event</div>
              <div class="cmd-description">Crear un evento programado en el servidor de Discord.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="crear" data-name="/create-role">
            <span class="cmd-num">08</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🛠️</span>/create-role</div>
              <div class="cmd-description">Crear un nuevo rol con permisos y color personalizados.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="crear" data-name="/create-emoji">
            <span class="cmd-num">09</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🛠️</span>/create-emoji</div>
              <div class="cmd-description">Crear un emoji personalizado para el servidor.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="crear" data-name="/create-sticker">
            <span class="cmd-num">10</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🛠️</span>/create-sticker</div>
              <div class="cmd-description">Crear un sticker personalizado para el servidor.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- EDICIÓN -->
      <div class="category-section" data-cat="editar">
        <div class="category-header">
          <div class="category-icon">✏️</div>
          <span class="category-name">Edición</span>
          <span class="category-count">5 comandos</span>
        </div>
        <div class="cmd-grid">
          <div class="cmd-card" data-cat="editar" data-name="/edit-server">
            <span class="cmd-num">11</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">✏️</span>/edit-server</div>
              <div class="cmd-description">Editar el nombre o la descripción del servidor.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="editar" data-name="/edit-channel">
            <span class="cmd-num">12</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">✏️</span>/edit-channel</div>
              <div class="cmd-description">Editar el nombre, descripción o permisos de un canal.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="editar" data-name="/edit-category">
            <span class="cmd-num">13</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">✏️</span>/edit-category</div>
              <div class="cmd-description">Editar el nombre o los permisos de una categoría.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="editar" data-name="/edit-event">
            <span class="cmd-num">14</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">✏️</span>/edit-event</div>
              <div class="cmd-description">Editar los detalles de un evento ya creado.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="editar" data-name="/edit-role">
            <span class="cmd-num">15</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">✏️</span>/edit-role</div>
              <div class="cmd-description">Editar el nombre, color o permisos de un rol existente.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- ELIMINACIÓN -->
      <div class="category-section" data-cat="borrar">
        <div class="category-header">
          <div class="category-icon">🗑️</div>
          <span class="category-name">Eliminación</span>
          <span class="category-count">6 comandos</span>
        </div>
        <div class="cmd-grid">
          <div class="cmd-card" data-cat="borrar" data-name="/delete-channel">
            <span class="cmd-num">16</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🗑️</span>/delete-channel</div>
              <div class="cmd-description">Borrar permanentemente un canal del servidor.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="borrar" data-name="/delete-category">
            <span class="cmd-num">17</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🗑️</span>/delete-category</div>
              <div class="cmd-description">Borrar permanentemente una categoría del servidor.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="borrar" data-name="/delete-event">
            <span class="cmd-num">18</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🗑️</span>/delete-event</div>
              <div class="cmd-description">Borrar un evento programado del servidor.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="borrar" data-name="/delete-role">
            <span class="cmd-num">19</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🗑️</span>/delete-role</div>
              <div class="cmd-description">Borrar un rol existente del servidor.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="borrar" data-name="/purge">
            <span class="cmd-num">20</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🆑</span>/purge</div>
              <div class="cmd-description">Borrar en masa mensajes del canal de forma rápida.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="borrar" data-name="/purge-user">
            <span class="cmd-num">21</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">🆑</span>/purge-user</div>
              <div class="cmd-description">Borrar mensajes específicos de un usuario en el canal.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- MODERACIÓN -->
      <div class="category-section" data-cat="mod">
        <div class="category-header">
          <div class="category-icon">🛡️</div>
          <span class="category-name">Moderación y Sanciones</span>
          <span class="category-count">10 comandos</span>
        </div>
        <div class="cmd-grid">
          <div class="cmd-card" data-cat="mod" data-name="/ban">
            <span class="cmd-num">22</span>
            <div class="cmd-info">
              <div class="cmd-tag"><span class="emoji">⛔</span>/ban</div>
              <div class="cmd-description">Expulsa permanentemente a un usuario del servidor.</div>
            </div>
          </div>
          <div class="cmd-card" data-cat="mod" data-name="/unban">
            <span class="cmd-num">23</span>
